---
import Base from '../../layouts/Base.astro';
import FinalCta from '../../components/FinalCta.astro';
const title = "Commercial Construction Management | Wright Construction Management";
const description = "Owner's representation, CM-at-risk, and GMP delivery for owners and developers tired of self-managing capital projects—preconstruction, budget and schedule oversight, contractor coordination, and risk management under one accountable partner.";
---
<Base title={title} description={description}>
  <section class="page-banner"><div class="wrap">
    <div class="breadcrumb"><a href="/">Home</a> / <a href="/services">Services</a> / Commercial CM</div>
    <span class="eyebrow" style="color:#ff8c87">Owner's Rep &middot; CM-at-Risk &middot; GMP</span>
    <h1>Commercial Construction Management for Owners Who Want Fewer Surprises.</h1>
    <p>One accountable partner for owners and developers tired of self-managing capital projects&mdash;preconstruction, budget and schedule oversight, contractor coordination, and risk management from concept through closeout.</p>
  </div></section>

  <section><div class="wrap"><div class="two-col" style="align-items:start">
    <div>
      <span class="eyebrow">What we do</span>
      <h2 class="section-title">We own the messy middle so your team doesn't have to.</h2>
      <p class="lead" style="margin-top:16px">When the owner's team becomes the default coordinator between designers, vendors, inspectors, and trades, things get missed&mdash;and the misses become delays, rework, and budget pressure. We're the operational translator who keeps everyone aligned.</p>
    </div>
    <div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">Who it's for</h4><p style="color:var(--muted)">Owners and developers tired of self-managing capital projects, juggling architects, GCs, MEP, and vendors&mdash;and tired of subcontractor finger-pointing and change-order surprises.</p></div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">The problem it solves</h4><p style="color:var(--muted)">Without a single accountable lead, coordination gaps turn into delays, rework, and budget pressure&mdash;and leadership can't confidently tell its board, lenders, or customers when the project will be done.</p></div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">What Wright CM does</h4><p style="color:var(--muted)">Preconstruction and budgeting, design and schedule oversight, contractor coordination, risk management, and closeout&mdash;delivered as owner's representation, CM-at-risk, or GMP.</p></div>
      <div class="qa"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">Why it matters</h4><p style="color:var(--muted)">One accountable partner means fewer gaps, fewer handoffs, and fewer change orders&mdash;and a leadership team that always knows exactly where the project stands.</p></div>
    </div>
  </div></div></section>

  <section class="section-soft"><div class="wrap">
    <span class="eyebrow">Capabilities</span>
    <h2 class="section-title">What's included.</h2>
    <div class="cap-grid">
      <div class="cap"><h4>Preconstruction</h4><p>Feasibility, budgeting, and early risk discovery.</p></div>
      <div class="cap"><h4>Budget &amp; Schedule Oversight</h4><p>ROM through GMP, with weekly cost-to-complete.</p></div>
      <div class="cap"><h4>Design Management</h4><p>Architects and engineers held to cost and speed.</p></div>
      <div class="cap"><h4>Contractor Coordination</h4><p>Bid leveling, buyout, and scope-gap closure.</p></div>
      <div class="cap"><h4>Risk Management</h4><p>Utility, AHJ, inspection, and phasing risk, forced early.</p></div>
      <div class="cap"><h4>Owner Visibility</h4><p>Our in-house dashboard shows cost, schedule, and design in real time.</p></div>
      <div class="cap"><h4>Closeout</h4><p>Punch velocity, commissioning, warranties, and O&amp;M.</p></div>
      <div class="cap"><h4>Flexible Delivery</h4><p>Owner's rep, CM-at-risk, or GMP&mdash;structured to fit your project.</p></div>
    </div>
  </div></div></section>

  <FinalCta heading="Tired of self-managing your capital projects?" sub="Book a 15-minute feasibility call and we'll talk through your project and the right delivery approach." label="Book a Feasibility Call" />
</Base>
