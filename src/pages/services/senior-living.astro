---
import Base from '../../layouts/Base.astro';
import FinalCta from '../../components/FinalCta.astro';
const title = "Senior Living & Assisted Living Construction | Wright Construction Management";
const description = "Owner-led design-build construction management for ground-up senior and assisted living—wood-frame schedules, HUD process familiarity, and a closeout cadence that keeps speed from costing quality.";
---
<Base title={title} description={description}>
  <section class="page-banner"><div class="wrap">
    <div class="breadcrumb"><a href="/">Home</a> / <a href="/services">Services</a> / Senior Living</div>
    <span class="eyebrow" style="color:#ff8c87">Senior Living Wood-Speed&trade;</span>
    <h1>Senior Living &amp; Assisted Living, Delivered on Schedule.</h1>
    <p>Owner-led design-build construction management for ground-up senior and assisted living&mdash;wood-frame projects where speed can't sacrifice quality, with HUD process familiarity built in.</p>
  </div></section>

  <section><div class="wrap"><div class="two-col" style="align-items:start">
    <div>
      <span class="eyebrow">What we do</span>
      <h2 class="section-title">Speed and finish consistency, without a messy closeout.</h2>
      <p class="lead" style="margin-top:16px">Wood-frame senior living lives and dies on schedule and finish consistency. We keep design, procurement, and field execution aligned to your opening date&mdash;and hand over a clean, well-documented building.</p>
    </div>
    <div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">Who it's for</h4><p style="color:var(--muted)">Developers and owners building ground-up senior and assisted living, teams navigating the HUD process and documentation cadence, and sites with environmental or due-diligence complications.</p></div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">The problem it solves</h4><p style="color:var(--muted)">HUD documentation, long-lead procurement, and a fixed opening date leave no room for scope gaps or a sloppy closeout&mdash;and a finish-heavy interior magnifies every miss.</p></div>
      <div class="qa" style="margin-bottom:20px"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">What Wright CM does</h4><p style="color:var(--muted)">Owner-led delivery from concept through closeout: buildable design details aligned to speed and budget, trade buyout and long-lead control, weekly field execution, and a turnover package with warranties, O&amp;M, and training logs.</p></div>
      <div class="qa"><h4 style="color:var(--red);font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px">Why it matters</h4><p style="color:var(--muted)">One accountable leader who knows HUD timing and stakeholder coordination keeps the project moving and the opening date intact&mdash;without the finish and closeout problems that erode operator confidence.</p></div>
    </div>
  </div></div></section>

  <section class="section-soft"><div class="wrap">
    <span class="eyebrow">Built for senior living</span>
    <h2 class="section-title">What's included.</h2>
    <div class="cap-grid">
      <div class="cap"><h4>Wood-Frame Scheduling</h4><p>Speed without sacrificing finish or quality.</p></div>
      <div class="cap"><h4>HUD Familiarity</h4><p>Process timing, documentation, and stakeholder coordination.</p></div>
      <div class="cap"><h4>Long-Lead Procurement</h4><p>Bid leveling, scope-gap closure, and order-by discipline.</p></div>
      <div class="cap"><h4>Finish Consistency</h4><p>A finish-heavy interior delivered to a fixed opening date.</p></div>
      <div class="cap"><h4>Due Diligence</h4><p>Environmental and site complications handled early.</p></div>
      <div class="cap"><h4>Turnover &amp; Closeout</h4><p>Warranties, O&amp;M, training logs, and clean punch closure.</p></div>
    </div>
  </div></div></section>

  <FinalCta heading="Planning a senior living community?" sub="Book a 15-minute feasibility call and we'll pressure-test the schedule, budget, and HUD path before you break ground." label="Book a Feasibility Call" />
</Base>
