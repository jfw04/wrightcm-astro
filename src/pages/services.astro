---
import Base from '../layouts/Base.astro';
import FinalCta from '../components/FinalCta.astro';
import data from '../data/content.json';
const title = "Services | Wright Construction Management";
const description = "Owner-led design-build construction management for food processing and USDA conversions, senior living, and commercial owners—preconstruction, budget and schedule oversight, contractor coordination, and risk management.";
---
<Base title={title} description={description}>
  <section class="page-banner"><div class="wrap">
    <div class="breadcrumb"><a href="/">Home</a> / Services</div>
    <h1>Services</h1>
    <p>One accountable, owner-led partner from feasibility through closeout. We go deepest in two sectors&mdash;food processing and senior living&mdash;and bring the same construction-management rigor to commercial owners tired of self-managing capital projects.</p>
  </div></section>

  <section><div class="wrap">
    <span class="eyebrow">What we do</span>
    <h2 class="section-title">Three ways we help owners build better, faster, with fewer surprises.</h2>
    <div class="svc-grid">
      {data.services.map((s) => (
        <a class="svc-card" href={`/services/${s.slug}`} style="text-decoration:none">
          <span class="svc-tag">{s.tag.replace('(TM)', '™')}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
          <span class="more">Explore this service →</span>
        </a>
      ))}
    </div>
  </div></section>

  <section class="section-soft"><div class="wrap">
    <span class="eyebrow">Capabilities</span>
    <h2 class="section-title">What's included across every engagement.</h2>
    <div class="cap-grid">
      <div class="cap"><h4>Preconstruction</h4><p>Feasibility, budgeting, and early risk discovery.</p></div>
      <div class="cap"><h4>Budget &amp; Schedule Oversight</h4><p>ROM through GMP, with weekly cost-to-complete.</p></div>
      <div class="cap"><h4>Design Management</h4><p>Architects and engineers held to cost and speed.</p></div>
      <div class="cap"><h4>Trade Buyout</h4><p>Bid leveling, scope-gap closure, procurement control.</p></div>
      <div class="cap"><h4>Equipment Coordination</h4><p>Design, utilities, delivery, and install with vendors.</p></div>
      <div class="cap"><h4>Risk Management</h4><p>Utility, AHJ, inspection, and phasing risk, forced early.</p></div>
      <div class="cap"><h4>Owner Visibility</h4><p>An in-house dashboard with cost, schedule, and design in real time.</p></div>
      <div class="cap"><h4>Closeout</h4><p>Punch velocity, commissioning, warranties, O&amp;M.</p></div>
    </div>

    <span class="eyebrow" style="display:block;margin-top:56px">How we engage</span>
    <h2 class="section-title">Flexible commercial terms&mdash;with skin in the game.</h2>
    <div class="eng-grid">
      <div class="eng"><div class="k">01</div><div><h4>Feasibility Study</h4><p>Reduce uncertainty before you commit; creditable toward precon/CM if you proceed.</p></div></div>
      <div class="eng"><div class="k">02</div><div><h4>Design-Build CM</h4><p>Percentage fee or fixed fee, project-dependent&mdash;single accountable partner.</p></div></div>
      <div class="eng"><div class="k">03</div><div><h4>CM-at-Risk / GMP</h4><p>Transparent buyout with clear allowance and contingency rules.</p></div></div>
      <div class="eng"><div class="k">04</div><div><h4>VE Savings Share</h4><p>Split net verified savings on approved value-engineering items, client-favored.</p></div></div>
      <div class="eng"><div class="k">05</div><div><h4>Schedule Achievement Bonus</h4><p>We tie a portion of our upside to agreed project milestones.</p></div></div>
      <div class="eng"><div class="k">06</div><div><h4>Schedule Buydown&trade;</h4><p>A defined acceleration plan to buy time back when speed-to-revenue is the priority.</p></div></div>
    </div>
  </div></section>

  <FinalCta heading="Not sure which engagement fits?" sub="Start with a 15-minute feasibility call. We'll identify the biggest cost, schedule, and operational risks and recommend the right path forward." />
</Base>
