---
import data from '../data/content.json';
const showNews = !!(data.news && data.news.enabled);
const LI = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77Z"/></svg>`;
---
<header class="site"><div class="wrap nav">
  <a class="brand" href="/" aria-label="Wright Construction Management home"><img src="/assets/img/logos/wcm-logo-notag.png" alt="Wright Construction Management" /></a>
  <nav><ul class="nav-links" id="navLinks">
    <li><a href="/">Home</a></li>
    <li class="has-drop"><a href="/services">Services &#9662;</a>
      <div class="dropdown">
        <a href="/services/food-processing-usda">Food Processing / USDA<span>Industrial Speed-to-Commission&trade;</span></a>
        <a href="/services/senior-living">Senior Living<span>Senior Living Wood-Speed&trade;</span></a>
        <a href="/services/commercial-construction-management">Commercial CM<span>Owner's rep &amp; CM-at-risk</span></a>
      </div></li>
    <li><a href="/projects">Projects</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/whitepapers">White Papers</a></li>
    {showNews && <li><a href="/news">News</a></li>}
    <li><a href="/careers">Careers</a></li>
    <li><a href="/contact">Contact</a></li>
  </ul></nav>
  <div class="nav-cta">
    <div class="nav-social"><a href="https://www.linkedin.com/company/wright-construction-management/about/" target="_blank" rel="noopener" aria-label="LinkedIn" set:html={LI}></a></div>
    <a href="/contact" class="btn btn-primary">Schedule a Call</a>
    <button class="burger" id="burger" aria-label="Menu"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg></button>
  </div>
</div>
<div class="tagline-bar"><span>Build Better</span></div>
</header>
